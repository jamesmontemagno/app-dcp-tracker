<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:DCPTracker.Models"
    xmlns:viewModels="clr-namespace:DCPTracker.ViewModels"
    x:Class="DCPTracker.Views.ProjectionsPage"
    x:DataType="viewModels:ProjectionsViewModel"
    Title="Projections">

    <Grid RowDefinitions="Auto,*" Padding="20,16" RowSpacing="14">

        <VerticalStackLayout Spacing="10">
            <Label Text="Distribution Projections" FontAttributes="Bold" FontSize="28" SemanticProperties.HeadingLevel="Level1" />
            <Label Text="{Binding WeightedAverageReturnLabel}" FontSize="13" />
            <Label Text="{Binding SummaryMessage}" FontSize="12" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label x:Name="TaxAdjustedLabel" Text="Show tax-adjusted amounts" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding ShowTaxAdjusted}"
                        SemanticProperties.Description="Show tax-adjusted amounts" />
            </Grid>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding TimelineRows}" SelectionMode="None">
            <CollectionView.Header>
                <Grid ColumnDefinitions="*,*,*" Padding="4,0,4,6" ColumnSpacing="8">
                    <Label Text="Month" FontAttributes="Bold" FontSize="12" />
                    <Label Grid.Column="1" Text="{Binding AmountColumnHeader}" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="2" Text="Cumulative Net" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="End" />
                </Grid>
            </CollectionView.Header>
            <CollectionView.EmptyView>
                <Label Padding="12" Text="No distribution months to show. Add buckets with future distribution dates." HorizontalTextAlignment="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:MonthlyDistributionRow">
                    <Border Padding="10" StrokeShape="RoundRectangle 6" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Label Text="{Binding MonthLabel}" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding NetLabel}" FontSize="13" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding CumulativeNetLabel}" FontSize="13" HorizontalTextAlignment="End" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
