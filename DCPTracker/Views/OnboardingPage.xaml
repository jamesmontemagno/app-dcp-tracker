<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:viewModels="clr-namespace:DCPTracker.ViewModels" x:Class="DCPTracker.Views.OnboardingPage" x:DataType="viewModels:OnboardingViewModel" Title="Welcome" Background="{DynamicResource PageBackgroundBrush}">
    <Grid RowDefinitions="*,Auto" Padding="24,20">
        <ScrollView>
            <VerticalStackLayout Spacing="18" VerticalOptions="Center">
                <Border Padding="10,6" HorizontalOptions="Start" Background="{DynamicResource AccentSoftBrush}" StrokeThickness="0" StrokeShape="RoundRectangle 8"><Label Text="DCP TRACKER" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource Primary}" /></Border>
                <Label Text="See deferred comp, equity, and retirement timing in one calm planning view." FontSize="32" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight}, Dark={StaticResource PrimaryTextDark}}" />
                <Label Text="Local-first modeling, deterministic scenarios, and in-app reminders designed for thoughtful planning rather than noisy advice." FontSize="15" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Border Padding="14" Background="{DynamicResource SurfaceBrush}" Stroke="{DynamicResource BorderBrush}" StrokeShape="RoundRectangle 8"><Label Text="Unify 401(k), DCP, RSU, ESPP, and event timing." /></Border>
                    <Border Grid.Row="1" Padding="14" Background="{DynamicResource SurfaceBrush}" Stroke="{DynamicResource BorderBrush}" StrokeShape="RoundRectangle 8"><Label Text="Stress test scenarios with assumptions you control." /></Border>
                    <Border Grid.Row="2" Padding="14" Background="{DynamicResource SurfaceBrush}" Stroke="{DynamicResource BorderBrush}" StrokeShape="RoundRectangle 8"><Label Text="Keep data on device while the app grows deeper." /></Border>
                </Grid>
                <Border Padding="16" Background="{DynamicResource SurfaceBrush}" Stroke="{DynamicResource BorderBrush}" StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout Spacing="10"><Label Text="Appearance and demo" FontAttributes="Bold" FontSize="16" /><Picker Title="Theme" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}" /><Grid ColumnDefinitions="*,Auto" ColumnSpacing="10"><Label Text="Start in Demo Mode" VerticalOptions="Center" /><Switch Grid.Column="1" IsToggled="{Binding IsDemoModeEnabled}" /></Grid></VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <Button Grid.Row="1" Text="Start planning" Command="{Binding CompleteCommand}" Margin="0,18,0,0" />
    </Grid>
</ContentPage>