<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:DCPTracker.ViewModels"
    x:Class="DCPTracker.Views.SettingsPage"
    x:DataType="viewModels:SettingsViewModel"
    Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">
            <Label Text="Settings" FontAttributes="Bold" FontSize="28" SemanticProperties.HeadingLevel="Level1" />

            <Border Padding="16" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Goals" FontAttributes="Bold" FontSize="18" SemanticProperties.HeadingLevel="Level2" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Entry Placeholder="Monthly goal ($)" Keyboard="Numeric" Text="{Binding MonthlyGoalInput}" />
                        <Entry Grid.Column="1" Placeholder="Default return %" Keyboard="Numeric" Text="{Binding DefaultReturnRateInput}" />
                        <Entry Grid.Row="1" Placeholder="Tax withholding %" Keyboard="Numeric" Text="{Binding TaxWithholdingRateInput}" />
                        <Picker Grid.Row="1" Grid.Column="1" Title="Theme" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}" />
                    </Grid>

                    <Button Text="Save settings" Command="{Binding SaveGoalsCommand}" />

                    <Label Text="{Binding ValidationMessage}" TextColor="#B42318" FontSize="12" />
                    <Label Text="{Binding StatusMessage}" FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Educational planning model. Confirm elections and distribution rules with official plan materials." FontSize="12" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
