<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:models="clr-namespace:DCPTracker.Models" xmlns:viewModels="clr-namespace:DCPTracker.ViewModels" x:Class="DCPTracker.Views.DataPage" x:DataType="viewModels:MainPageViewModel" Title="Data">
    <Grid Padding="20,16" RowDefinitions="Auto,*" RowSpacing="14">
        <VerticalStackLayout Spacing="14">
            <Label Text="Accounts and imports" FontAttributes="Bold" FontSize="28" />
            <Border Padding="16" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="10"><Label Text="{Binding AccountEditorTitle}" FontAttributes="Bold" FontSize="18" /><Entry Placeholder="Account name" Text="{Binding NewAccountName}" /><Grid ColumnDefinitions="*,*" ColumnSpacing="10"><Picker Title="Account type" ItemsSource="{Binding SupportedAccountTypes}" SelectedItem="{Binding SelectedAccountType}" /><Entry Grid.Column="1" Keyboard="Numeric" Placeholder="Balance" Text="{Binding NewAccountBalance}" /></Grid><Grid ColumnDefinitions="*,*,*" ColumnSpacing="8"><Button Text="{Binding AccountSaveLabel}" Command="{Binding SaveAccountCommand}" /><Button Grid.Column="1" Text="New" Command="{Binding StartNewAccountCommand}" /><Button Grid.Column="2" Text="Delete" Command="{Binding DeleteSelectedAccountCommand}" /></Grid><Label Text="{Binding ValidationMessage}" TextColor="#B42318" FontSize="12" /></VerticalStackLayout></Border>
            <Border Padding="16" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="10"><Label Text="Paste import" FontAttributes="Bold" FontSize="18" /><Editor Placeholder="Name, Type, Balance" Text="{Binding ImportText}" AutoSize="TextChanges" MinimumHeightRequest="88" /><Label Text="{Binding ImportSummary}" FontSize="12" /><Button Text="Import snapshots" Command="{Binding ImportAccountsCommand}" /></VerticalStackLayout></Border>
        </VerticalStackLayout>
        <CollectionView Grid.Row="1" ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}" SelectionMode="Single"><CollectionView.EmptyView><Label Padding="12" Text="No accounts yet. Add or import a snapshot above." HorizontalTextAlignment="Center" /></CollectionView.EmptyView><CollectionView.ItemTemplate><DataTemplate x:DataType="models:RetirementAccount"><Border Padding="14" StrokeShape="RoundRectangle 8" Margin="0,0,0,10"><Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4"><Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" /><Label Grid.Column="1" Text="{Binding Balance, StringFormat='{0:C0}'}" FontAttributes="Bold" /><Label Grid.Row="1" Text="{Binding AccountTypeLabel}" FontSize="12" /><Label Grid.Row="1" Grid.Column="1" Text="Select to edit" FontSize="12" /></Grid></Border></DataTemplate></CollectionView.ItemTemplate></CollectionView>
    </Grid>
</ContentPage>
