<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:DCPTracker.ViewModels"
    x:Class="DCPTracker.Views.DashboardPage"
    x:DataType="viewModels:DashboardViewModel"
    Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">

            <Label Text="DCP Dashboard" FontAttributes="Bold" FontSize="30" SemanticProperties.HeadingLevel="Level1" />
            <Label Text="{Binding StatusMessage}" FontSize="12" />

            <!-- Summary cards -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Padding="14" StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Total current value" FontSize="12" />
                        <Label Text="{Binding TotalCurrentBalance, StringFormat='{0:C0}'}" FontAttributes="Bold" FontSize="24" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Padding="14" StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Deferral buckets" FontSize="12" />
                        <Label Text="{Binding BucketCount}" FontAttributes="Bold" FontSize="24" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Monthly payout goal -->
            <Border Padding="14" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Monthly distribution goal" FontAttributes="Bold" FontSize="16" />
                    <Label Text="{Binding GoalProgressLabel}" FontSize="13" />
                    <ProgressBar Progress="{Binding GoalProgress}" />
                    <Label Text="{Binding CurrentMonthlyPayout, StringFormat='Current monthly payout: {0:C0}'}" FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- Upcoming distributions -->
            <Border Padding="14" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Upcoming distributions" FontAttributes="Bold" FontSize="16" SemanticProperties.HeadingLevel="Level2" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding UpcomingDistributions}" Spacing="4">
                        <BindableLayout.EmptyView>
                            <Label Text="No upcoming distribution windows. Add buckets with future start dates." FontSize="12" />
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Label Text="{Binding .}" FontSize="13" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
