<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:models="clr-namespace:DCPTracker.Models" xmlns:viewModels="clr-namespace:DCPTracker.ViewModels" x:Class="DCPTracker.Views.DashboardPage" x:DataType="viewModels:MainPageViewModel" Title="Dashboard">
    <Grid Padding="20,16" RowDefinitions="*">
        <CollectionView ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}" SelectionMode="Single">
            <CollectionView.ItemsLayout><LinearItemsLayout Orientation="Vertical" ItemSpacing="12" /></CollectionView.ItemsLayout>
            <CollectionView.Header>
                <VerticalStackLayout Margin="0,0,0,16" Spacing="16">
                    <VerticalStackLayout Spacing="4"><Label Text="DCP Tracker" FontAttributes="Bold" FontSize="30" SemanticProperties.HeadingLevel="Level1" /><Label Text="{Binding DashboardSummary}" /><Label Text="{Binding StatusMessage}" FontSize="12" /></VerticalStackLayout>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <Border Padding="14" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="6"><Label Text="Tracked total" FontSize="12" /><Label Text="{Binding TotalTrackedBalance, StringFormat='{0:C0}'}" FontAttributes="Bold" FontSize="24" /></VerticalStackLayout></Border>
                        <Border Grid.Column="1" Padding="14" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="6"><Label Text="Accounts" FontSize="12" /><Label Text="{Binding TrackedAccountCount}" FontAttributes="Bold" FontSize="24" /></VerticalStackLayout></Border>
                        <Border Grid.Row="1" Grid.ColumnSpan="2" Padding="14" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="6"><Label Text="Employer stock lens" FontSize="12" /><Label Text="{Binding ConcentrationSummary}" FontAttributes="Bold" FontSize="20" /><ProgressBar Progress="{Binding EmployerStockConcentration}" /></VerticalStackLayout></Border>
                    </Grid>
                    <Border Padding="16" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="10"><Label Text="{Binding AccountEditorTitle}" FontAttributes="Bold" FontSize="18" SemanticProperties.HeadingLevel="Level2" /><Entry Placeholder="Account name" Text="{Binding NewAccountName}" /><Grid ColumnDefinitions="*,*" ColumnSpacing="10"><Picker Title="Account type" ItemsSource="{Binding SupportedAccountTypes}" SelectedItem="{Binding SelectedAccountType}" /><Entry Grid.Column="1" Keyboard="Numeric" Placeholder="Balance" Text="{Binding NewAccountBalance}" /></Grid><Grid ColumnDefinitions="*,*,*" ColumnSpacing="8"><Button Text="{Binding AccountSaveLabel}" Command="{Binding SaveAccountCommand}" /><Button Grid.Column="1" Text="New" Command="{Binding StartNewAccountCommand}" /><Button Grid.Column="2" Text="Delete" Command="{Binding DeleteSelectedAccountCommand}" /></Grid><Label Text="{Binding ValidationMessage}" TextColor="#B42318" FontSize="12" /></VerticalStackLayout></Border>
                    <Border Padding="16" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="10"><Label Text="Paste import" FontAttributes="Bold" FontSize="18" SemanticProperties.HeadingLevel="Level2" /><Editor Placeholder="Name, Type, Balance" Text="{Binding ImportText}" AutoSize="TextChanges" MinimumHeightRequest="88" /><Label Text="{Binding ImportSummary}" FontSize="12" /><Button Text="Import snapshots" Command="{Binding ImportAccountsCommand}" /></VerticalStackLayout></Border>
                    <Border Padding="16" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="10"><Label Text="Planning assumptions" FontAttributes="Bold" FontSize="18" SemanticProperties.HeadingLevel="Level2" /><Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10"><Entry Placeholder="Retirement age" Keyboard="Numeric" Text="{Binding RetirementAgeInput}" /><Entry Grid.Column="1" Placeholder="Annual contributions" Keyboard="Numeric" Text="{Binding AnnualContributionInput}" /><Entry Grid.Row="1" Placeholder="Growth %" Keyboard="Numeric" Text="{Binding ExpectedGrowthPercentInput}" /><Picker Grid.Row="1" Grid.Column="1" Title="Tax bracket" ItemsSource="{Binding TaxBracketOptions}" SelectedItem="{Binding SelectedTaxBracket}" /><Entry Grid.Row="2" Placeholder="Watch concentration %" Keyboard="Numeric" Text="{Binding ConcentrationWarningPercentInput}" /><Entry Grid.Row="2" Grid.Column="1" Placeholder="Critical concentration %" Keyboard="Numeric" Text="{Binding ConcentrationCriticalPercentInput}" /><Picker Grid.Row="3" Grid.ColumnSpan="2" Title="Appearance" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}" /></Grid><Grid ColumnDefinitions="*,Auto" ColumnSpacing="10"><Label Text="Demo Mode uses in-memory sample data" VerticalOptions="Center" /><Switch Grid.Column="1" IsToggled="{Binding IsDemoModeEnabled}" /></Grid><Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="6"><CheckBox IsChecked="{Binding ShowAlerts}" /><Label Grid.Column="1" Text="Alerts" VerticalOptions="Center" /><CheckBox Grid.Column="2" IsChecked="{Binding ShowTimeline}" /><Label Grid.Column="3" Text="Timeline" VerticalOptions="Center" /><CheckBox Grid.Column="4" IsChecked="{Binding ShowScenarios}" /><Label Grid.Column="5" Text="Scenarios" VerticalOptions="Center" /></Grid><Button Text="Save assumptions" Command="{Binding SavePlanningAssumptionsCommand}" /></VerticalStackLayout></Border>
                    <Border Padding="16" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="10"><Label Text="Timeline event" FontAttributes="Bold" FontSize="18" SemanticProperties.HeadingLevel="Level2" /><Entry Placeholder="Event title" Text="{Binding EventTitle}" /><Grid ColumnDefinitions="*,*" ColumnSpacing="10"><Picker Title="Event type" ItemsSource="{Binding SupportedEventTypes}" SelectedItem="{Binding SelectedEventType}" /><DatePicker Grid.Column="1" Date="{Binding EventDate}" /></Grid><Entry Placeholder="Estimated amount" Keyboard="Numeric" Text="{Binding EventEstimatedAmount}" /><Button Text="Add event" Command="{Binding SavePlanningEventCommand}" /></VerticalStackLayout></Border>
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowAlerts}" BindableLayout.ItemsSource="{Binding Alerts}"><Label Text="Alerts and insights" FontAttributes="Bold" FontSize="18" SemanticProperties.HeadingLevel="Level2" /><BindableLayout.ItemTemplate><DataTemplate x:DataType="models:DashboardAlert"><Border Padding="12" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="3"><Label Text="{Binding Severity}" FontAttributes="Bold" FontSize="12" /><Label Text="{Binding Title}" FontAttributes="Bold" /><Label Text="{Binding Detail}" FontSize="12" /></VerticalStackLayout></Border></DataTemplate></BindableLayout.ItemTemplate></VerticalStackLayout>
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowTimeline}" BindableLayout.ItemsSource="{Binding PlanningEvents}"><Label Text="Upcoming timeline" FontAttributes="Bold" FontSize="18" SemanticProperties.HeadingLevel="Level2" /><BindableLayout.ItemTemplate><DataTemplate x:DataType="models:PlanningEvent"><Border Padding="12" StrokeShape="RoundRectangle 8"><Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="3"><Label Text="{Binding Title}" FontAttributes="Bold" /><Label Grid.Column="1" Text="{Binding EstimatedAmount, StringFormat='{0:C0}'}" FontAttributes="Bold" /><Label Grid.Row="1" Text="{Binding EventType}" FontSize="12" /><Label Grid.Row="1" Grid.Column="1" Text="{Binding EventDateLabel}" FontSize="12" /></Grid></Border></DataTemplate></BindableLayout.ItemTemplate></VerticalStackLayout>
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowScenarios}" BindableLayout.ItemsSource="{Binding Scenarios}"><Label Text="Deterministic scenarios" FontAttributes="Bold" FontSize="18" SemanticProperties.HeadingLevel="Level2" /><BindableLayout.ItemTemplate><DataTemplate x:DataType="models:ScenarioProjection"><Border Padding="12" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="5"><Label Text="{Binding Name}" FontAttributes="Bold" /><Label Text="{Binding AssumptionSummary}" FontSize="12" /><Grid ColumnDefinitions="*,*,*" ColumnSpacing="8"><Label Text="{Binding ProjectedBalance, StringFormat='{0:C0}'}" FontAttributes="Bold" /><Label Grid.Column="1" Text="{Binding EstimatedAnnualIncome, StringFormat='{0:C0}/yr'}" FontAttributes="Bold" HorizontalTextAlignment="Center" /><Label Grid.Column="2" Text="{Binding EstimatedTaxWithholding, StringFormat='Tax {0:C0}'}" HorizontalTextAlignment="End" /></Grid><Label Text="{Binding Narrative}" FontSize="12" /></VerticalStackLayout></Border></DataTemplate></BindableLayout.ItemTemplate></VerticalStackLayout>
                    <Label Text="Tracked accounts" FontAttributes="Bold" FontSize="18" SemanticProperties.HeadingLevel="Level2" />
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.EmptyView><Label Padding="12" Text="No accounts yet. Add or import the first snapshot above." HorizontalTextAlignment="Center" /></CollectionView.EmptyView>
            <CollectionView.ItemTemplate><DataTemplate x:DataType="models:RetirementAccount"><Border Padding="14" StrokeShape="RoundRectangle 8"><Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4"><Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" /><Label Grid.Column="1" Text="{Binding Balance, StringFormat='{0:C0}'}" FontAttributes="Bold" HorizontalTextAlignment="End" /><Label Grid.Row="1" Text="{Binding AccountTypeLabel}" FontSize="12" /><Label Grid.Row="1" Grid.Column="1" Text="Select to edit" FontSize="12" HorizontalTextAlignment="End" /></Grid></Border></DataTemplate></CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
