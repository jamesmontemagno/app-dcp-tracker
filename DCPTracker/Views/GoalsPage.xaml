<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:models="clr-namespace:DCPTracker.Models" xmlns:viewModels="clr-namespace:DCPTracker.ViewModels" x:Class="DCPTracker.Views.GoalsPage" x:DataType="viewModels:MainPageViewModel" Title="Goals">
    <ScrollView><VerticalStackLayout Padding="20,16" Spacing="14">
        <Label Text="Goals and scenarios" FontAttributes="Bold" FontSize="28" />
        <Border Padding="16" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="10"><Label Text="Planning assumptions" FontAttributes="Bold" FontSize="18" /><Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10"><Entry Placeholder="Retirement age" Keyboard="Numeric" Text="{Binding RetirementAgeInput}" /><Entry Grid.Column="1" Placeholder="Annual contributions" Keyboard="Numeric" Text="{Binding AnnualContributionInput}" /><Entry Grid.Row="1" Placeholder="Growth %" Keyboard="Numeric" Text="{Binding ExpectedGrowthPercentInput}" /><Picker Grid.Row="1" Grid.Column="1" Title="Tax bracket" ItemsSource="{Binding TaxBracketOptions}" SelectedItem="{Binding SelectedTaxBracket}" /><Entry Grid.Row="2" Placeholder="Watch concentration %" Keyboard="Numeric" Text="{Binding ConcentrationWarningPercentInput}" /><Entry Grid.Row="2" Grid.Column="1" Placeholder="Critical concentration %" Keyboard="Numeric" Text="{Binding ConcentrationCriticalPercentInput}" /><Picker Grid.Row="3" Grid.ColumnSpan="2" Title="Appearance" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}" /></Grid><Grid ColumnDefinitions="*,Auto" ColumnSpacing="10"><Label Text="Demo Mode uses in-memory sample data" VerticalOptions="Center" /><Switch Grid.Column="1" IsToggled="{Binding IsDemoModeEnabled}" /></Grid><Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="6"><CheckBox IsChecked="{Binding ShowAlerts}" /><Label Grid.Column="1" Text="Alerts" VerticalOptions="Center" /><CheckBox Grid.Column="2" IsChecked="{Binding ShowTimeline}" /><Label Grid.Column="3" Text="Timeline" VerticalOptions="Center" /><CheckBox Grid.Column="4" IsChecked="{Binding ShowScenarios}" /><Label Grid.Column="5" Text="Scenarios" VerticalOptions="Center" /></Grid><Button Text="Save assumptions" Command="{Binding SavePlanningAssumptionsCommand}" /><Label Text="{Binding ValidationMessage}" TextColor="#B42318" FontSize="12" /></VerticalStackLayout></Border>
        <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding Scenarios}"><Label Text="Deterministic scenario outputs" FontAttributes="Bold" FontSize="18" /><BindableLayout.ItemTemplate><DataTemplate x:DataType="models:ScenarioProjection"><Border Padding="12" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="5"><Label Text="{Binding Name}" FontAttributes="Bold" /><Label Text="{Binding AssumptionSummary}" FontSize="12" /><Grid ColumnDefinitions="*,*,*" ColumnSpacing="8"><Label Text="{Binding ProjectedBalance, StringFormat='{0:C0}'}" FontAttributes="Bold" /><Label Grid.Column="1" Text="{Binding EstimatedAnnualIncome, StringFormat='{0:C0}/yr'}" FontAttributes="Bold" HorizontalTextAlignment="Center" /><Label Grid.Column="2" Text="{Binding EstimatedTaxWithholding, StringFormat='Tax {0:C0}'}" HorizontalTextAlignment="End" /></Grid><Label Text="{Binding Narrative}" FontSize="12" /></VerticalStackLayout></Border></DataTemplate></BindableLayout.ItemTemplate></VerticalStackLayout>
    </VerticalStackLayout></ScrollView>
</ContentPage>
