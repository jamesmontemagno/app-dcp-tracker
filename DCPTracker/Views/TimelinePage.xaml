<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:models="clr-namespace:DCPTracker.Models" xmlns:viewModels="clr-namespace:DCPTracker.ViewModels" x:Class="DCPTracker.Views.TimelinePage" x:DataType="viewModels:MainPageViewModel" Title="Timeline">
    <Grid Padding="20,16" RowDefinitions="Auto,*" RowSpacing="14">
        <VerticalStackLayout Spacing="14">
            <Label Text="Timeline and reminders" FontAttributes="Bold" FontSize="28" />
            <Border Padding="16" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="10"><Label Text="Add planning event" FontAttributes="Bold" FontSize="18" /><Entry Placeholder="Event title" Text="{Binding EventTitle}" /><Grid ColumnDefinitions="*,*" ColumnSpacing="10"><Picker Title="Event type" ItemsSource="{Binding SupportedEventTypes}" SelectedItem="{Binding SelectedEventType}" /><DatePicker Grid.Column="1" Date="{Binding EventDate}" /></Grid><Entry Placeholder="Estimated amount" Keyboard="Numeric" Text="{Binding EventEstimatedAmount}" /><Button Text="Add event" Command="{Binding SavePlanningEventCommand}" /><Label Text="{Binding ValidationMessage}" TextColor="#B42318" FontSize="12" /></VerticalStackLayout></Border>
            <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding Alerts}"><Label Text="In-app alerts" FontAttributes="Bold" FontSize="18" /><BindableLayout.ItemTemplate><DataTemplate x:DataType="models:DashboardAlert"><Border Padding="12" StrokeShape="RoundRectangle 8"><VerticalStackLayout Spacing="3"><Label Text="{Binding Severity}" FontAttributes="Bold" FontSize="12" /><Label Text="{Binding Title}" FontAttributes="Bold" /><Label Text="{Binding Detail}" FontSize="12" /></VerticalStackLayout></Border></DataTemplate></BindableLayout.ItemTemplate></VerticalStackLayout>
        </VerticalStackLayout>
        <CollectionView Grid.Row="1" ItemsSource="{Binding PlanningEvents}" SelectionMode="None"><CollectionView.EmptyView><Label Padding="12" Text="No timeline events yet." HorizontalTextAlignment="Center" /></CollectionView.EmptyView><CollectionView.ItemTemplate><DataTemplate x:DataType="models:PlanningEvent"><Border Padding="12" StrokeShape="RoundRectangle 8" Margin="0,0,0,10"><Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="3"><Label Text="{Binding Title}" FontAttributes="Bold" /><Label Grid.Column="1" Text="{Binding EstimatedAmount, StringFormat='{0:C0}'}" FontAttributes="Bold" /><Label Grid.Row="1" Text="{Binding EventType}" FontSize="12" /><Label Grid.Row="1" Grid.Column="1" Text="{Binding EventDateLabel}" FontSize="12" /></Grid></Border></DataTemplate></CollectionView.ItemTemplate></CollectionView>
    </Grid>
</ContentPage>
