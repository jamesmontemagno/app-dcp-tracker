<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DCPTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DCPTracker.Views"
    Title="DCPTracker">

    <TabBar>
        <ShellContent Title="Dashboard" ContentTemplate="{DataTemplate views:DashboardPage}" Route="DashboardPage" />
        <ShellContent Title="Buckets" ContentTemplate="{DataTemplate views:BucketsPage}" Route="BucketsPage" />
        <ShellContent Title="Projections" ContentTemplate="{DataTemplate views:ProjectionsPage}" Route="ProjectionsPage" />
        <ShellContent Title="Settings" ContentTemplate="{DataTemplate views:SettingsPage}" Route="SettingsPage" />
    </TabBar>

</Shell>
